# Root convenience file. Copy the client and server examples into their own .env files.

# Client
VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME="Legal and Field Consultancy Firms"

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/legal_field_consultancy"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET="replace-with-a-different-long-random-refresh-secret"
REFRESH_TOKEN_EXPIRES_IN_DAYS=7
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
UPLOAD_DIR=uploads
