generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum LawyerStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

enum Priority {
  HIGH
  MEDIUM
  REGULAR
}

enum AppointmentStatus {
  PENDING
  RESCHEDULE_REQUESTED
  SCHEDULED
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum ConflictStatus {
  PENDING_ASSIGNMENT
  CLEAR
  WARNING
  CONFLICT
}

enum LocationMode {
  IN_PERSON
  PHONE
  FIELD
}

enum AvailabilityType {
  AVAILABLE
  UNAVAILABLE
  RESERVED
}

model Role {
  id          String   @id @default(cuid()) @db.VarChar(32)
  slug        String   @unique @db.VarChar(40)
  name        String   @db.VarChar(80)
  description String?  @db.VarChar(255)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model User {
  id                   String               @id @default(cuid()) @db.VarChar(32)
  roleId               String               @db.VarChar(32)
  name                 String               @db.VarChar(120)
  email                String               @unique @db.VarChar(160)
  phone                String?              @db.VarChar(40)
  passwordHash         String               @db.VarChar(255)
  status               UserStatus           @default(ACTIVE)
  role                 Role                 @relation(fields: [roleId], references: [id])
  lawyerProfile        Lawyer?
  refreshTokens        RefreshToken[]
  loginAttempts        LoginAttempt[]
  clientAppointments   Appointment[]        @relation("ClientAppointments")
  assignedAppointments Appointment[]        @relation("AssignedAppointments")
  notifications        Notification[]
  documents            Document[]
  auditLogs            AuditLog[]
  activityLogs         ActivityLog[]
  updatedSettings      SystemSetting[]
  appointmentHistory   AppointmentHistory[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([roleId])
  @@index([status])
  @@map("users")
}

model Lawyer {
  id                    String          @id @default(cuid()) @db.VarChar(32)
  userId                String          @unique @db.VarChar(32)
  barNumber             String          @unique @db.VarChar(80)
  specialization        String          @db.VarChar(160)
  bio                   String?         @db.Text
  yearsExperience       Int             @default(0)
  hourlyRate            Decimal?        @db.Decimal(10, 2)
  maxDailyConsultations Int             @default(8)
  status                LawyerStatus    @default(ACTIVE)
  user                  User            @relation(fields: [userId], references: [id])
  schedules             Schedule[]
  availability          Availability[]
  appointments          Appointment[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([status])
  @@map("lawyers")
}

model Appointment {
  id                 String               @id @default(cuid()) @db.VarChar(32)
  clientId           String               @db.VarChar(32)
  lawyerId           String?              @db.VarChar(32)
  assignedById       String?              @db.VarChar(32)
  consultationType   String               @db.VarChar(120)
  subject            String               @db.VarChar(180)
  description        String               @db.Text
  priority           Priority             @default(REGULAR)
  requestedPriority  Priority?
  priorityReason     String?              @db.VarChar(255)
  status             AppointmentStatus    @default(PENDING)
  preferredStart     DateTime
  preferredEnd       DateTime
  scheduledStart     DateTime?
  scheduledEnd       DateTime?
  locationMode       LocationMode         @default(IN_PERSON)
  conflictStatus     ConflictStatus       @default(PENDING_ASSIGNMENT)
  cancellationReason String?              @db.VarChar(500)
  rescheduleReason   String?              @db.VarChar(500)
  client             User                 @relation("ClientAppointments", fields: [clientId], references: [id])
  lawyer             Lawyer?              @relation(fields: [lawyerId], references: [id])
  assignedBy         User?                @relation("AssignedAppointments", fields: [assignedById], references: [id])
  documents          Document[]
  history            AppointmentHistory[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([clientId])
  @@index([lawyerId])
  @@index([assignedById])
  @@index([status])
  @@index([priority])
  @@index([scheduledStart])
  @@index([conflictStatus])
  @@index([clientId, preferredStart])
  @@map("appointments")
}

model Schedule {
  id              String   @id @default(cuid()) @db.VarChar(32)
  lawyerId        String   @db.VarChar(32)
  dayOfWeek       Int
  startTime       String   @db.VarChar(5)
  endTime         String   @db.VarChar(5)
  isAvailable     Boolean  @default(true)
  maxAppointments Int      @default(8)
  effectiveFrom   DateTime?
  effectiveTo     DateTime?
  lawyer          Lawyer   @relation(fields: [lawyerId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([lawyerId, dayOfWeek, startTime])
  @@index([lawyerId])
  @@map("schedules")
}

model Availability {
  id              String           @id @default(cuid()) @db.VarChar(32)
  lawyerId        String           @db.VarChar(32)
  type            AvailabilityType @default(AVAILABLE)
  startsAt        DateTime
  endsAt          DateTime
  reason          String?          @db.VarChar(255)
  maxAppointments Int?
  lawyer          Lawyer           @relation(fields: [lawyerId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([lawyerId])
  @@index([startsAt, endsAt])
  @@map("availability")
}

model Notification {
  id        String    @id @default(cuid()) @db.VarChar(32)
  userId    String    @db.VarChar(32)
  title     String    @db.VarChar(160)
  message   String    @db.VarChar(500)
  type      String    @db.VarChar(60)
  actionUrl String?   @db.VarChar(255)
  metadata  Json?
  readAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([readAt])
  @@map("notifications")
}

model Document {
  id            String      @id @default(cuid()) @db.VarChar(32)
  appointmentId String      @db.VarChar(32)
  uploadedById  String      @db.VarChar(32)
  fileName      String      @db.VarChar(255)
  filePath      String      @db.VarChar(500)
  mimeType      String      @db.VarChar(120)
  size          Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  uploadedBy    User        @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime    @default(now())

  @@index([appointmentId])
  @@index([uploadedById])
  @@map("uploaded_documents")
}

model AppointmentHistory {
  id            String      @id @default(cuid()) @db.VarChar(32)
  appointmentId String      @db.VarChar(32)
  actorId       String?     @db.VarChar(32)
  action        String      @db.VarChar(80)
  note          String?     @db.VarChar(500)
  metadata      Json?
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  actor         User?       @relation(fields: [actorId], references: [id])
  createdAt     DateTime    @default(now())

  @@index([appointmentId])
  @@index([actorId])
  @@map("appointment_history")
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid()) @db.VarChar(32)
  metric    String   @db.VarChar(100)
  value     Decimal  @db.Decimal(12, 2)
  dimension Json?
  capturedAt DateTime @default(now())

  @@index([metric])
  @@index([capturedAt])
  @@map("analytics")
}

model AuditLog {
  id        String   @id @default(cuid()) @db.VarChar(32)
  userId    String?  @db.VarChar(32)
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String?  @db.VarChar(80)
  metadata  Json?
  ipAddress String?  @db.VarChar(80)
  userAgent String?  @db.VarChar(255)
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id        String   @id @default(cuid()) @db.VarChar(32)
  userId    String?  @db.VarChar(32)
  action    String   @db.VarChar(100)
  summary   String   @db.VarChar(255)
  metadata  Json?
  ipAddress String?  @db.VarChar(80)
  userAgent String?  @db.VarChar(255)
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

model RefreshToken {
  id          String    @id @default(cuid()) @db.VarChar(32)
  userId      String    @db.VarChar(32)
  tokenHash   String    @unique @db.VarChar(128)
  familyId    String    @db.VarChar(64)
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedBy  String?   @db.VarChar(128)
  ipAddress   String?   @db.VarChar(80)
  userAgent   String?   @db.VarChar(255)
  user         User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model LoginAttempt {
  id        String   @id @default(cuid()) @db.VarChar(32)
  userId    String?  @db.VarChar(32)
  email     String   @db.VarChar(160)
  success   Boolean
  reason    String?  @db.VarChar(160)
  ipAddress String?  @db.VarChar(80)
  userAgent String?  @db.VarChar(255)
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([createdAt])
  @@map("login_attempts")
}

model SystemSetting {
  id          String   @id @default(cuid()) @db.VarChar(32)
  key         String   @unique @db.VarChar(80)
  value       Json
  updatedById String?  @db.VarChar(32)
  updatedBy   User?    @relation(fields: [updatedById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([updatedById])
  @@map("system_settings")
}
